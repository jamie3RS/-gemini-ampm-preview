{{!< default}}
{{!-- Work index — case studies listing.
    Routed to /work/ via routes.yaml as a Ghost Collection. --}}

<section class="section">
  <div class="reveal" style="margin-bottom: 24px;">
    <div class="eyebrow">Work · Case studies</div>
    <h1 class="display">Buildings, evidenced.</h1>
    <p class="deck" style="margin-top: 16px; max-width: 60ch;">
      Selected work from across the group. Compliance-led, audit-ready, delivered through the enterprise stack the mid-market rarely has.
    </p>
  </div>
</section>

{{#if posts}}
<section class="section" style="padding-top: 0;">
  <div class="work-grid reveal">
    {{#foreach posts}}
      {{> "work-card"}}
    {{/foreach}}
  </div>

  {{#if pagination.next}}
  <div class="reveal" style="margin-top: 56px; text-align: center;">
    <a href="{{page_url pagination.next}}" style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; border: 1px solid var(--ink); padding: 14px 24px; display: inline-block;">Older case studies →</a>
  </div>
  {{/if}}
</section>
{{else}}
<section class="section">
  <p class="deck">No case studies published yet. The first will appear here as soon as it's ready.</p>
</section>
{{/if}}

<section class="section dark">
  <div class="section-inner">
    {{> "newsletter"}}
  </div>
</section>
