{{!< default}}
{{#author}}
<section class="section">
  <div class="reveal" style="margin-bottom: 24px;">
    <div class="eyebrow">Author</div>
    <h1 class="display">{{name}}</h1>
    {{#if bio}}<p class="deck" style="margin-top: 16px; max-width: 60ch;">{{bio}}</p>{{/if}}
  </div>
</section>
{{/author}}

{{#if posts}}
<section class="section" style="padding-top: 0;">
  <div class="insights-list reveal">
    {{#foreach posts}}
      {{#has tag="case-study"}}{{> "work-card"}}{{else}}{{> "insight-card"}}{{/has}}
    {{/foreach}}
  </div>
  {{pagination}}
</section>
{{/if}}
