{{!-- Ghost Members signup form. Ghost intercepts data-members-form. --}}
<div class="newsletter">
  <div class="newsletter-inner">
    <div>
      <div class="eyebrow on-dark" style="margin-bottom: 14px;">Mothership briefings</div>
      <h3 class="display" style="font-size: clamp(36px, 4vw, 56px); color: var(--paper);">
        One thoughtful piece on compliance, EOTs, and the buildings buyers can't afford to fail. Once a month. <em>Nothing else.</em>
      </h3>
    </div>
    <form class="newsletter-form" data-members-form="signup">
      <input data-members-email type="email" name="email" placeholder="name@yourorganisation.com" aria-label="Email address" required>
      <button type="submit">Subscribe →</button>
      <div class="newsletter-note">No tracking pixels. No "growth-hacked" sequence. Unsubscribe in one click.</div>
      <div class="newsletter-success" data-members-success>Thanks — check your inbox to confirm.</div>
      <div class="newsletter-error" data-members-error>Something went wrong. Try again, or email hello@ampm.co.uk.</div>
    </form>
  </div>
</div>
