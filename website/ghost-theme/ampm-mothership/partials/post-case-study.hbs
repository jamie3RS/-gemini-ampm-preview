{{!-- Case study post layout. Markdown body is rendered as-is; the layout
    around it (dark header, meta strip, cover image) is template-driven. --}}

<article class="article">
  <header class="article-header is-dark">
    <div class="article-header-inner">
      <div class="reveal" style="display:flex;flex-direction:column;gap:10px;">
        <div class="eyebrow on-dark">
          Case study
          {{#primary_tag}} · {{name}}{{/primary_tag}}
        </div>
        {{> "meridian-bar" max_width=420}}
      </div>

      <div class="reveal">
        <h1 class="display" style="color: var(--paper); max-width: 22ch;">{{title}}</h1>
        {{#if custom_excerpt}}
          <p class="deck" style="margin-top: 28px; color: rgba(246,243,236,0.85);">{{custom_excerpt}}</p>
        {{/if}}
      </div>

      <dl class="article-meta reveal">
        {{#if primary_tag}}<div><dt>Lead company</dt><dd>{{primary_tag.name}}</dd></div>{{/if}}
        <div><dt>Year</dt><dd>{{date format="YYYY"}}</dd></div>
        {{#if tags}}
          <div style="grid-column: span 2;">
            <dt>Scope</dt>
            <dd>
              {{#foreach tags from="2"}}{{name}}{{#unless @last}}, {{/unless}}{{/foreach}}
            </dd>
          </div>
        {{/if}}
        {{#if primary_author}}<div><dt>Author</dt><dd>{{primary_author.name}}</dd></div>{{/if}}
      </dl>
    </div>
  </header>

  {{#if feature_image}}
    <div class="article-cover reveal">
      <img src="{{img_url feature_image size="xl"}}" alt="{{title}}" style="width: 100%; aspect-ratio: 21 / 9; object-fit: cover; display: block;">
    </div>
  {{/if}}

  <section class="article-section reveal">
    <div class="article-section-inner two-col">
      <div class="article-aside">
        <div class="eyebrow">Case study</div>
      </div>
      <div class="article-body">
        {{!-- Author body. Markdown headings (## section) and quotes
            (> "pull quote") render with the case-study CSS scoped to .article-body. --}}
        {{content}}
      </div>
    </div>
  </section>
</article>

{{!-- Related case studies --}}
{{#get "posts" filter="tag:case-study+id:-{{post.id}}" limit="3" as |related|}}
{{#if related}}
<section class="section">
  <div class="reveal" style="margin-bottom: 32px; display: flex; justify-content: space-between; align-items: baseline;">
    <h3 class="display" style="font-size: clamp(28px, 3vw, 40px);">Other work from the group</h3>
    <a href="/work/" style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; border-bottom: 1px solid var(--ink); padding-bottom: 4px;">See all →</a>
  </div>
  <div class="work-grid reveal">
    {{#foreach related}}
      {{> "work-card"}}
    {{/foreach}}
  </div>
</section>
{{/if}}
{{/get}}

{{!-- Talk-to-us CTA --}}
<section class="section dark">
  <div class="section-inner">
    <div class="two-col reveal">
      <div>
        <div class="eyebrow on-dark">Talk to us</div>
        <h2 class="display" style="font-size: clamp(28px, 3vw, 44px);">An estate of your own that needs taking off the risk register?</h2>
      </div>
      <div style="display: flex; flex-direction: column; justify-content: flex-end; gap: 18px;">
        <div style="font-family: var(--serif); font-size: 22px; color: var(--paper);">bids@ampm.co.uk</div>
        <a href="/contact/" style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; border-bottom: 1px solid rgba(246,243,236,0.5); padding-bottom: 4px; color: var(--paper); display: inline-block; align-self: flex-start;">All contact routes →</a>
      </div>
    </div>
  </div>
</section>
