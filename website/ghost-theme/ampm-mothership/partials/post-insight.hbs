{{!-- Insight post layout. Long-form editorial. Markdown body
    rendered in .prose with section headings, pull quotes, images. --}}

<article class="article">
  <header class="article-header is-light">
    <div class="article-header-inner narrow">
      <div class="reveal">
        <div class="eyebrow">
          Insight
          {{#primary_tag}} · {{name}}{{/primary_tag}}
          · {{reading_time}}
        </div>
      </div>

      <div class="reveal">
        <h1 class="display" style="max-width: 20ch;">{{title}}</h1>
        {{#if custom_excerpt}}
          <p class="deck" style="margin-top: 24px; max-width: 52ch;">{{custom_excerpt}}</p>
        {{/if}}
      </div>

      {{#primary_author}}
      <div class="byline reveal">
        {{#if profile_image}}
          <img class="byline-avatar" src="{{img_url profile_image size="s"}}" alt="{{name}}" style="border-radius: 50%; width: 44px; height: 44px; object-fit: cover;">
        {{else}}
          <div class="byline-avatar"></div>
        {{/if}}
        <div class="byline-text">
          <div class="byline-name">{{name}}</div>
          {{#if bio}}<div class="byline-role">{{bio}}</div>{{/if}}
        </div>
        <div class="byline-date">{{date format="DD MMM YYYY"}}</div>
      </div>
      {{/primary_author}}
    </div>
  </header>

  {{#if feature_image}}
    <div style="max-width: 880px; margin: 40px auto 0; padding: 0 36px;">
      <img src="{{img_url feature_image size="l"}}" alt="{{title}}" style="width: 100%; aspect-ratio: 16 / 9; object-fit: cover; display: block;">
      {{#if feature_image_caption}}
        <div class="caption" style="margin-top: 12px;">{{{feature_image_caption}}}</div>
      {{/if}}
    </div>
  {{/if}}

  <div class="prose reveal">
    {{content}}
  </div>

  <section class="section">
    {{> "newsletter"}}
  </section>
</article>

{{!-- Related insights --}}
{{#get "posts" filter="tag:insight+id:-{{post.id}}" limit="3" as |related|}}
{{#if related}}
<section class="section">
  <div class="reveal" style="margin-bottom: 32px; display: flex; justify-content: space-between; align-items: baseline;">
    <h3 class="display" style="font-size: clamp(28px, 3vw, 40px);">More from the group</h3>
    <a href="/insights/" style="font-family: var(--mono); font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; border-bottom: 1px solid var(--ink); padding-bottom: 4px;">See all →</a>
  </div>
  <div class="insights-list reveal">
    {{#foreach related}}
      {{> "insight-card"}}
    {{/foreach}}
  </div>
</section>
{{/if}}
{{/get}}
