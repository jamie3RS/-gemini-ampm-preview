{{!< default}}
{{!-- Tag archive — used when a topic / company tag is browsed.
    Renders as either an insights list or a work list depending on tag slug pattern. --}}

{{#tag}}
<section class="section">
  <div class="reveal" style="margin-bottom: 24px;">
    <div class="eyebrow">Tag · {{name}}</div>
    <h1 class="display">All under <em>"{{name}}"</em></h1>
    {{#if description}}
      <p class="deck" style="margin-top: 16px; max-width: 60ch;">{{description}}</p>
    {{/if}}
  </div>
</section>
{{/tag}}

{{#if posts}}
<section class="section" style="padding-top: 0;">
  <div class="insights-list reveal">
    {{#foreach posts}}
      {{#has tag="case-study"}}
        {{> "work-card"}}
      {{else}}
        {{> "insight-card"}}
      {{/has}}
    {{/foreach}}
  </div>

  {{pagination}}
</section>
{{else}}
<section class="section"><p class="deck">No posts yet under this tag.</p></section>
{{/if}}
